#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v uv >/dev/null 2>&1; then
  echo "Error: uv is required to run Shay from a source checkout." >&2
  echo "Install uv or use an installed 'shay' entrypoint instead." >&2
  exit 1
fi

exec uv run --project "$ROOT" python -m shay_cli.main "$@"
